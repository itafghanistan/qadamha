---
import Base from '../../../layouts/Base.astro';
import StoryCard from '../../../components/StoryCard.astro';
import { LOCALES, useTranslations, type Locale } from '../../../i18n';
import { getStories } from '../../../lib/stories';
import { buildFilterIndex } from '../../../lib/story-utils';
import { SECTORS, STATUSES, REASONS } from '../../../content.config';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const stories = await getStories(locale);
const index = buildFilterIndex(stories);

const cities = [...new Set(index.map((s) => s.city))].sort();
const years = [...new Set(index.map((s) => s.yearStart))].sort((a, b) => b - a);
const usedSectors = SECTORS.filter((s) => index.some((e) => e.sector === s));
const usedReasons = REASONS.filter((r) => index.some((e) => e.reasons.includes(r)));

const filterLabels = {
  results: t('stories.results', { count: '{count}' }),
};
---

<Base
  locale={locale}
  title={`${t('stories.title')} — ${t('site.name')}`}
  description={t('stories.subtitle')}
  path="/stories/"
>
  <section class="section">
    <div class="container">
      <h1>{t('stories.title')}</h1>
      <p class="page-subtitle">{t('stories.subtitle')}</p>

      <form class="filters" id="filters" aria-label={t('filters.reason')}>
        <label>
          <span>{t('filters.sector')}</span>
          <select name="sector">
            <option value="">{t('filters.all')}</option>
            {usedSectors.map((s) => <option value={s}>{t(`sector.${s}`)}</option>)}
          </select>
        </label>
        <label>
          <span>{t('filters.city')}</span>
          <select name="city">
            <option value="">{t('filters.all')}</option>
            {cities.map((c) => <option value={c}>{c}</option>)}
          </select>
        </label>
        <label>
          <span>{t('filters.year')}</span>
          <select name="year">
            <option value="">{t('filters.all')}</option>
            {years.map((y) => <option value={String(y)}>{y}</option>)}
          </select>
        </label>
        <label>
          <span>{t('filters.status')}</span>
          <select name="status">
            <option value="">{t('filters.all')}</option>
            {STATUSES.map((s) => <option value={s}>{t(`status.${s}`)}</option>)}
          </select>
        </label>
        <label>
          <span>{t('filters.reason')}</span>
          <select name="reason">
            <option value="">{t('filters.all')}</option>
            {usedReasons.map((r) => <option value={r}>{t(`reason.${r}`)}</option>)}
          </select>
        </label>
        <button type="reset" class="btn btn-ghost">{t('stories.clearFilters')}</button>
      </form>

      <p class="result-count" id="result-count" data-template={filterLabels.results}>
        {t('stories.results', { count: stories.length })}
      </p>

      <div class="card-grid" id="story-grid">
        {stories.map((story) => <StoryCard story={story} locale={locale} />)}
      </div>

      <p class="no-results" id="no-results" hidden>{t('stories.noResults')}</p>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('filters') as HTMLFormElement;
  const grid = document.getElementById('story-grid')!;
  const cards = [...grid.querySelectorAll<HTMLElement>('[data-slug]')];
  const countEl = document.getElementById('result-count')!;
  const noResults = document.getElementById('no-results')!;
  const template = countEl.dataset.template ?? '{count}';

  function apply() {
    const data = new FormData(form);
    const sector = data.get('sector') as string;
    const city = data.get('city') as string;
    const year = data.get('year') as string;
    const status = data.get('status') as string;
    const reason = data.get('reason') as string;

    let visible = 0;
    for (const card of cards) {
      const yearStart = Number(card.dataset.yearStart);
      const yearEnd = card.dataset.yearEnd ? Number(card.dataset.yearEnd) : null;
      const matches =
        (!sector || card.dataset.sector === sector) &&
        (!city || card.dataset.city === city) &&
        (!year ||
          (yearStart <= Number(year) && (yearEnd === null || yearEnd >= Number(year)))) &&
        (!status || card.dataset.status === status) &&
        (!reason || (card.dataset.reasons ?? '').split(' ').includes(reason));
      card.hidden = !matches;
      if (matches) visible++;
    }
    countEl.textContent = template.replace('{count}', String(visible));
    noResults.hidden = visible > 0;

    // Sync state to URL so filtered views are shareable.
    const params = new URLSearchParams();
    for (const [key, value] of data.entries()) {
      if (value) params.set(key, value as string);
    }
    const query = params.toString();
    history.replaceState(null, '', query ? `?${query}` : location.pathname);
  }

  form.addEventListener('input', apply);
  form.addEventListener('reset', () => queueMicrotask(apply));

  // Restore state from URL on load.
  const params = new URLSearchParams(location.search);
  for (const [key, value] of params.entries()) {
    const field = form.elements.namedItem(key);
    if (field instanceof HTMLSelectElement) field.value = value;
  }
  if ([...params.keys()].length > 0) apply();
</script>

<style>
  .page-subtitle {
    color: var(--text-muted);
    max-width: 44rem;
    margin-block-end: 2rem;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: end;
    padding: 1.1rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-block-end: 1.25rem;
  }

  .filters label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .filters select {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.4rem 0.6rem;
    font-family: inherit;
    font-size: 0.92rem;
    min-inline-size: 8.5rem;
  }

  .filters select:focus-visible {
    outline: 2px solid var(--accent);
  }

  .filters button {
    padding-block: 0.42rem;
    font-size: 0.9rem;
  }

  .result-count {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-block-end: 1.25rem;
  }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding-block: 3rem;
    font-size: 1.05rem;
  }
</style>
