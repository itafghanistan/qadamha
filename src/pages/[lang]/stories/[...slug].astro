---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import StoryCard from '../../../components/StoryCard.astro';
import {
  LOCALE_META,
  formatNumber,
  localizePath,
  useTranslations,
  type Locale,
} from '../../../i18n';
import { getStories, getTranslations, type Story } from '../../../lib/stories';
import { getRelated, parseStoryId } from '../../../lib/story-utils';
import { GITHUB_REPO, GITHUB_STORY_PATH, SITE_URL } from '../../../config';

export async function getStaticPaths() {
  const entries = await getCollection('stories', (entry) => !entry.data.draft);
  return entries.map((entry) => {
    const { locale, slug } = parseStoryId(entry.id);
    return { params: { lang: locale, slug }, props: { entry } };
  });
}

const { entry } = Astro.props as { entry: Story };
const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const { slug } = parseStoryId(entry.id);
const { Content } = await render(entry);

const data = entry.data;
const availableLocales = await getTranslations(slug);
const otherLocales = availableLocales.filter((l) => l !== locale);
const missingLocales = (['en', 'fa', 'ps'] as Locale[]).filter(
  (l) => !availableLocales.includes(l),
);
const related = getRelated(entry, await getStories(locale));

const years =
  formatNumber(locale, data.yearsActive.start) +
  '–' +
  (data.yearsActive.end ? formatNumber(locale, data.yearsActive.end) : t('story.present'));

const path = `/stories/${slug}/`;
const pageUrl = new URL(localizePath(locale, path), SITE_URL).href;
const shareText = `${data.name} — ${data.tagline}`;
const shareLinks = [
  { label: 'X', url: `https://x.com/intent/post?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}` },
  { label: 'Facebook', url: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}` },
  { label: 'LinkedIn', url: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}` },
  { label: 'Telegram', url: `https://t.me/share/url?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(shareText)}` },
  { label: 'WhatsApp', url: `https://wa.me/?text=${encodeURIComponent(`${shareText} ${pageUrl}`)}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.name,
  description: data.tagline,
  inLanguage: LOCALE_META[locale].htmlLang,
  url: pageUrl,
  author: data.founders.map((f) => ({ '@type': 'Person', name: f.name })),
  publisher: { '@type': 'Organization', name: 'Qadamha', url: SITE_URL },
};
---

<Base
  locale={locale}
  title={`${data.name} — ${t('site.name')}`}
  description={data.tagline}
  path={path}
  availableLocales={availableLocales}
  ogImage={`/og/stories/${locale}/${slug}.png`}
  ogType="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="section">
    <div class="container story-layout">
      <div class="story-main">
        <header>
          <h1>{data.name}</h1>
          <p class="story-tagline">{data.tagline}</p>
          {
            otherLocales.length > 0 && (
              <p class="translations">
                {t('story.alsoAvailable')}
                {otherLocales.map((l) => (
                  <a href={localizePath(l, path)} lang={LOCALE_META[l].htmlLang} class="chip">
                    {LOCALE_META[l].nativeName}
                  </a>
                ))}
              </p>
            )
          }
        </header>

        <div class="prose">
          <Content />
        </div>

        {
          missingLocales.length > 0 && (
            <aside class="translate-invite">
              {missingLocales.map((l) => (
                <p>
                  <a href={localizePath(locale, '/contribute/')}>
                    {t('story.helpTranslate', { language: LOCALE_META[l].nativeName })}
                  </a>
                </p>
              ))}
            </aside>
          )
        }

        <div class="share-row">
          <span class="share-label">{t('story.share')}</span>
          {
            shareLinks.map((link) => (
              <a class="chip chip-muted" href={link.url} rel="noopener" target="_blank">
                {link.label}
              </a>
            ))
          }
          <button class="chip chip-muted copy-btn" data-url={pageUrl} data-copied={t('story.copied')}>
            {t('story.copyLink')}
          </button>
        </div>

        <p class="edit-link">
          <a href={`${GITHUB_STORY_PATH}/${locale}/${slug}.md`} rel="noopener">
            {t('story.editOnGitHub')}
          </a>
        </p>
      </div>

      <aside class="story-side">
        <dl>
          <dt>{t('story.status')}</dt>
          <dd><span class="chip">{t(`status.${data.status}`)}</span></dd>

          <dt>{t('story.reasons')}</dt>
          <dd class="chips">
            {data.reasons.map((r) => <span class="chip chip-muted">{t(`reason.${r}`)}</span>)}
          </dd>

          <dt>{t('story.years')}</dt>
          <dd>{years}</dd>

          <dt>{t('story.city')}</dt>
          <dd>{data.city}</dd>

          <dt>{t('story.sector')}</dt>
          <dd>{t(`sector.${data.sector}`)}</dd>

          <dt>{t('story.founders')}</dt>
          <dd>
            <ul>
              {
                data.founders.map((f) => (
                  <li>
                    {f.link ? <a href={f.link} rel="noopener">{f.name}</a> : f.name}
                    {f.role && <span class="role"> — {f.role}</span>}
                  </li>
                ))
              }
            </ul>
          </dd>

          {
            data.team && data.team.length > 0 && (
              <>
                <dt>{t('story.team')}</dt>
                <dd>
                  <ul>
                    {data.team.map((m) => (
                      <li>
                        {m.name}
                        {m.role && <span class="role"> — {m.role}</span>}
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )
          }

          {
            data.links && data.links.length > 0 && (
              <>
                <dt>{t('story.links')}</dt>
                <dd>
                  <ul>
                    {data.links.map((l) => (
                      <li>
                        <a href={l.url} rel="noopener">
                          {l.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )
          }

          {
            data.sources && data.sources.length > 0 && (
              <>
                <dt>{t('story.sources')}</dt>
                <dd>
                  <ul>
                    {data.sources.map((s) => (
                      <li>
                        <a href={s.url} rel="noopener">
                          {s.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )
          }
        </dl>
      </aside>
    </div>

    {
      related.length > 0 && (
        <div class="container related">
          <h2>{t('story.related')}</h2>
          <div class="card-grid">
            {related.map((story) => (
              <StoryCard story={story} locale={locale} />
            ))}
          </div>
        </div>
      )
    }
  </article>
</Base>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy-btn');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(btn.dataset.url ?? location.href);
    const original = btn.textContent;
    btn.textContent = btn.dataset.copied ?? original;
    setTimeout(() => (btn.textContent = original), 1600);
  });
</script>

<style>
  .story-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 17rem;
    gap: 3rem;
  }

  .story-tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .translations {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .story-side dl {
    position: sticky;
    inset-block-start: 4.5rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin: 0;
    font-size: 0.92rem;
  }

  .story-side dt {
    color: var(--text-muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-block-start: 1rem;
  }

  .story-side dt:first-child {
    margin-block-start: 0;
  }

  .story-side dd {
    margin: 0.25rem 0 0;
  }

  .story-side ul {
    margin: 0;
    padding-inline-start: 1.1rem;
  }

  .story-side .role {
    color: var(--text-muted);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .translate-invite {
    background: var(--accent-soft);
    border-radius: var(--radius);
    padding: 0.9rem 1.2rem;
    margin-block: 1.5rem;
    font-size: 0.95rem;
  }

  .translate-invite p {
    margin: 0;
  }

  .share-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-block: 2rem 0.75rem;
  }

  .share-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-inline-end: 0.35rem;
  }

  .copy-btn {
    cursor: pointer;
    font-family: inherit;
  }

  .edit-link {
    font-size: 0.88rem;
  }

  .related {
    margin-block-start: 3.5rem;
  }

  @media (max-width: 56rem) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .story-side dl {
      position: static;
    }
  }
</style>
