---
import Base from '../../layouts/Base.astro';
import IdeaCard from '../../components/IdeaCard.astro';
import { LOCALES, formatYear, useTranslations, type Locale } from '../../i18n';
import { getIdeas } from '../../lib/ideas';
import { groupByYear } from '../../lib/content-utils';
import type { Idea } from '../../lib/ideas';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const ideas = await getIdeas(locale);
const groups = groupByYear(ideas);

/** Years that have a historical context line in the dictionaries. */
const CONTEXT_YEARS = [2021, 2020, 2014];

/** Flatten year groups into rows; cards alternate sides of the center spine. */
type Row =
  | { kind: 'year'; year: number; context: string | null }
  | { kind: 'idea'; idea: Idea; side: 'start' | 'end'; delay: number };

let cardIndex = 0;
const rows: Row[] = groups.flatMap((group): Row[] => [
  {
    kind: 'year',
    year: group.year,
    context: CONTEXT_YEARS.includes(group.year) ? t(`timeline.context.${group.year}`) : null,
  },
  ...group.ideas.map((idea, i): Row => {
    const side: 'start' | 'end' = cardIndex++ % 2 === 0 ? 'start' : 'end';
    return { kind: 'idea', idea, side, delay: i * 90 };
  }),
]);
---

<Base
  locale={locale}
  title={`${t('timeline.title')} — ${t('site.name')}`}
  description={t('timeline.subtitle')}
  path="/timeline/"
>
  <section class="section">
    <div class="container">
      <h1>{t('timeline.title')}</h1>
      <p class="page-subtitle">{t('timeline.subtitle')}</p>

      <ol class="timeline" id="timeline">
        <div class="t-track" aria-hidden="true">
          <div class="t-progress" id="t-progress"></div>
        </div>
        {
          rows.map((row) =>
            row.kind === 'year' ? (
              <li class="t-year">
                <span class="year-badge reveal-pop">{formatYear(locale, row.year)}</span>
                {row.context && <p class="year-context reveal-pop">{row.context}</p>}
              </li>
            ) : (
              <li
                class={`t-item side-${row.side} reveal-slide`}
                style={`--d: ${row.delay}ms`}
              >
                <IdeaCard idea={row.idea} locale={locale} />
              </li>
            ),
          )
        }
      </ol>
    </div>
  </section>
</Base>

<script>
  // Reveal rows as they enter the viewport.
  const items = document.querySelectorAll('.reveal-slide, .reveal-pop');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px' },
    );
    items.forEach((el) => observer.observe(el));
  } else {
    items.forEach((el) => el.classList.add('is-visible'));
  }

  // The spine fills with light as the reader travels down the years.
  const timeline = document.getElementById('timeline');
  const progress = document.getElementById('t-progress');
  if (timeline && progress) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const rect = timeline.getBoundingClientRect();
      const anchor = window.innerHeight * 0.72;
      const filled = Math.min(Math.max(anchor - rect.top, 0), rect.height);
      progress.style.blockSize = `${filled}px`;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>

<style>
  .page-subtitle {
    color: var(--text-muted);
    max-width: 44rem;
    margin-block-end: 2.5rem;
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 1rem 0 2rem;
    position: relative;
  }

  /* The spine */
  .t-track {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 50%;
    inline-size: 3px;
    margin-inline-start: -1.5px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .t-progress {
    inline-size: 100%;
    block-size: 0;
    background: linear-gradient(to bottom, var(--accent-strong), var(--accent));
    box-shadow: 0 0 14px rgba(232, 163, 61, 0.6);
  }

  /* Year badges sit on the spine */
  .t-year {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-block: 2.75rem 1.75rem;
  }

  .t-year:first-of-type {
    margin-block-start: 0.5rem;
  }

  .year-badge {
    display: inline-block;
    padding: 0.3rem 1.5rem;
    border: 2px solid var(--accent);
    border-radius: 999px;
    background: var(--bg);
    color: var(--accent-strong);
    font-size: 1.3rem;
    font-weight: 800;
    box-shadow:
      0 0 0 6px var(--bg),
      0 0 24px rgba(232, 163, 61, 0.25);
  }

  .year-context {
    max-width: 30rem;
    margin: 0;
    padding: 0.2rem 1rem;
    background: var(--bg);
    color: var(--text-muted);
    font-style: italic;
    font-size: 0.95rem;
    text-align: center;
  }

  /* Cards alternate sides of the spine */
  .t-item {
    position: relative;
    z-index: 1;
    inline-size: calc(50% - 2.75rem);
    margin-block-end: 1.75rem;
  }

  .t-item.side-start {
    margin-inline-end: auto;
  }

  .t-item.side-end {
    margin-inline-start: auto;
  }

  /* Connector from card to spine, with a node dot on the line */
  .t-item::before {
    content: '';
    position: absolute;
    inset-block-start: 2.1rem;
    inline-size: 2.75rem;
    block-size: 2px;
    background: var(--border);
  }

  .t-item::after {
    content: '';
    position: absolute;
    inset-block-start: calc(2.1rem - 5px);
    inline-size: 12px;
    block-size: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }

  .t-item.side-start::before {
    inset-inline-end: -2.75rem;
  }

  .t-item.side-start::after {
    inset-inline-end: calc(-2.75rem - 7px);
  }

  .t-item.side-end::before {
    inset-inline-start: -2.75rem;
  }

  .t-item.side-end::after {
    inset-inline-start: calc(-2.75rem - 7px);
  }

  .t-item.is-visible::after {
    background: var(--accent);
    box-shadow: 0 0 12px rgba(232, 163, 61, 0.7);
  }

  /* Animations (skipped entirely under prefers-reduced-motion) */
  @media (prefers-reduced-motion: no-preference) {
    .reveal-slide {
      opacity: 0;
      transform: translateX(var(--from, 0)) translateY(10px);
      transition:
        opacity 0.6s ease,
        transform 0.65s cubic-bezier(0.22, 0.9, 0.3, 1);
      transition-delay: var(--d, 0ms);
    }

    .side-start {
      --from: -44px;
    }

    .side-end {
      --from: 44px;
    }

    [dir='rtl'] .side-start {
      --from: 44px;
    }

    [dir='rtl'] .side-end {
      --from: -44px;
    }

    .reveal-pop {
      opacity: 0;
      transform: scale(0.55);
      transition:
        opacity 0.45s ease,
        transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .reveal-slide.is-visible,
    .reveal-pop.is-visible {
      opacity: 1;
      transform: none;
    }
  }

  /* Narrow screens: spine moves to the side, cards stack on one side */
  @media (max-width: 56rem) {
    .t-track {
      inset-inline-start: 0.45rem;
      margin-inline-start: 0;
    }

    .t-year {
      align-items: flex-start;
      margin-block: 2.25rem 1.25rem;
    }

    .year-badge,
    .year-context {
      margin-inline-start: 2rem;
      text-align: start;
      padding-inline: 1rem 0.5rem;
    }

    .year-badge {
      box-shadow: 0 0 0 6px var(--bg);
    }

    .t-item,
    .t-item.side-start,
    .t-item.side-end {
      inline-size: auto;
      margin-inline: 2rem 0;
    }

    .t-item.side-start::before,
    .t-item.side-end::before {
      inset-inline-start: -1.55rem;
      inset-inline-end: auto;
      inline-size: 1.55rem;
    }

    .t-item.side-start::after,
    .t-item.side-end::after {
      inset-inline-start: calc(-1.55rem - 6px);
      inset-inline-end: auto;
    }

    @media (prefers-reduced-motion: no-preference) {
      .side-start,
      .side-end,
      [dir='rtl'] .side-start,
      [dir='rtl'] .side-end {
        --from: 0px;
      }
    }
  }
</style>
