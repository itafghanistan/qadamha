---
import Base from '../../layouts/Base.astro';
import IdeaCard from '../../components/IdeaCard.astro';
import { LOCALES, formatYear, useTranslations, type Locale } from '../../i18n';
import { getIdeas } from '../../lib/ideas';
import { groupByYear } from '../../lib/content-utils';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const ideas = await getIdeas(locale);
const groups = groupByYear(ideas);

/** Years that have a historical context line in the dictionaries. */
const CONTEXT_YEARS = [2021, 2020, 2014];
---

<Base
  locale={locale}
  title={`${t('timeline.title')} — ${t('site.name')}`}
  description={t('timeline.subtitle')}
  path="/timeline/"
>
  <section class="section">
    <div class="container timeline-head">
      <div>
        <h1>{t('timeline.title')}</h1>
        <p class="page-subtitle">{t('timeline.subtitle')}</p>
      </div>
      <div class="h-nav" aria-hidden="false">
        <button class="h-btn" id="h-prev" aria-label={t('timeline.prev')}>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 6-6 6 6 6"></path>
          </svg>
        </button>
        <button class="h-btn" id="h-next" aria-label={t('timeline.next')}>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 6 6 6-6 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="h-scroll" id="h-scroll" tabindex="0" role="region" aria-label={t('timeline.title')}>
      <div class="h-inner">
        <div class="h-spine" aria-hidden="true">
          <div class="h-progress" id="h-progress"></div>
        </div>
        <ol class="h-cols">
          {
            groups.map((group, gi) => (
              <li class="h-col" style={`--d: ${Math.min(gi, 4) * 110}ms`}>
                <span class="year-badge reveal-pop">{formatYear(locale, group.year)}</span>
                {CONTEXT_YEARS.includes(group.year) && (
                  <p class="year-context reveal-rise">{t(`timeline.context.${group.year}`)}</p>
                )}
                <div class="h-cards">
                  {group.ideas.map((idea, i) => (
                    <div class="h-card reveal-rise" style={`--d: ${Math.min(gi, 4) * 110 + i * 120}ms`}>
                      <IdeaCard idea={idea} locale={locale} />
                    </div>
                  ))}
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>
</Base>

<script>
  const scroller = document.getElementById('h-scroll')!;
  const progress = document.getElementById('h-progress')!;
  const isRtl = document.documentElement.dir === 'rtl';

  // Reveal columns and cards as they scroll into view horizontally.
  const items = document.querySelectorAll('.reveal-pop, .reveal-rise');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { root: scroller, rootMargin: '0px -6% 0px -6%' },
    );
    items.forEach((el) => observer.observe(el));
  } else {
    items.forEach((el) => el.classList.add('is-visible'));
  }

  // The spine fills with light as the reader travels through the years.
  let ticking = false;
  const updateProgress = () => {
    ticking = false;
    const traveled = Math.abs(scroller.scrollLeft) + scroller.clientWidth * 0.6;
    progress.style.inlineSize = `${Math.min(traveled, scroller.scrollWidth)}px`;
  };
  const onScroll = () => {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(updateProgress);
    }
  };
  scroller.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  updateProgress();

  // Mouse wheels scroll vertically; translate that into horizontal travel.
  scroller.addEventListener(
    'wheel',
    (event) => {
      if (Math.abs(event.deltaY) > Math.abs(event.deltaX)) {
        event.preventDefault();
        scroller.scrollLeft += (isRtl ? -event.deltaY : event.deltaY) * 1.4;
      }
    },
    { passive: false },
  );

  // Arrow buttons step one column at a time.
  const step = () => {
    const col = scroller.querySelector<HTMLElement>('.h-col');
    return (col?.offsetWidth ?? 320) + 32;
  };
  document.getElementById('h-prev')?.addEventListener('click', () => {
    scroller.scrollBy({ left: (isRtl ? 1 : -1) * step(), behavior: 'smooth' });
  });
  document.getElementById('h-next')?.addEventListener('click', () => {
    scroller.scrollBy({ left: (isRtl ? -1 : 1) * step(), behavior: 'smooth' });
  });
</script>

<style>
  .timeline-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-block-end: 2rem;
  }

  .page-subtitle {
    color: var(--text-muted);
    max-width: 44rem;
    margin: 0;
  }

  .h-nav {
    display: flex;
    gap: 0.6rem;
  }

  .h-btn {
    display: grid;
    place-items: center;
    inline-size: 2.75rem;
    block-size: 2.75rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-raised);
    color: var(--text);
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease;
  }

  .h-btn:hover,
  .h-btn:focus-visible {
    border-color: var(--accent);
    color: var(--accent-strong);
    transform: translateY(-2px);
  }

  [dir='rtl'] .h-btn svg {
    transform: scaleX(-1);
  }

  /* The horizontal scroll stage */
  .h-scroll {
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x proximity;
    padding-block-end: 1.25rem;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) var(--bg-raised);
  }

  .h-scroll:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .h-inner {
    position: relative;
    inline-size: max-content;
    min-inline-size: 100%;
    padding-block-start: 0.6rem;
    padding-inline: max(1.25rem, calc((100vw - var(--content-width)) / 2));
  }

  /* The spine the years sit on */
  .h-spine {
    position: absolute;
    inset-inline: 0;
    inset-block-start: 1.9rem;
    block-size: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .h-progress {
    block-size: 100%;
    inline-size: 0;
    background: linear-gradient(to var(--progress-dir, right), var(--accent-strong), var(--accent));
    box-shadow: 0 0 14px rgba(232, 163, 61, 0.6);
  }

  [dir='rtl'] .h-progress {
    --progress-dir: left;
    margin-inline-start: auto;
  }

  .h-cols {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .h-col {
    position: relative;
    inline-size: clamp(17rem, 21rem, 80vw);
    flex-shrink: 0;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }

  /* Vertical drop-line from the spine down to the cards */
  .h-col::before {
    content: '';
    position: absolute;
    inset-block-start: 2.6rem;
    inset-inline-start: 50%;
    inline-size: 2px;
    block-size: 1.6rem;
    background: var(--border);
  }

  .year-badge {
    position: relative;
    z-index: 1;
    display: inline-block;
    padding: 0.25rem 1.4rem;
    border: 2px solid var(--accent);
    border-radius: 999px;
    background: var(--bg);
    color: var(--accent-strong);
    font-size: 1.25rem;
    font-weight: 800;
    box-shadow:
      0 0 0 6px var(--bg),
      0 0 24px rgba(232, 163, 61, 0.25);
  }

  .year-context {
    margin: 0.9rem 0 0;
    color: var(--text-muted);
    font-style: italic;
    font-size: 0.9rem;
    text-align: center;
    max-inline-size: 19rem;
  }

  .h-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    inline-size: 100%;
    margin-block-start: 1rem;
  }

  /* Animations (skipped entirely under prefers-reduced-motion) */
  @media (prefers-reduced-motion: no-preference) {
    .reveal-pop {
      opacity: 0;
      transform: scale(0.55);
      transition:
        opacity 0.45s ease,
        transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
      transition-delay: var(--d, 0ms);
    }

    .reveal-rise {
      opacity: 0;
      transform: translateY(26px);
      transition:
        opacity 0.55s ease,
        transform 0.6s cubic-bezier(0.22, 0.9, 0.3, 1);
      transition-delay: var(--d, 0ms);
    }

    .reveal-pop.is-visible,
    .reveal-rise.is-visible {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 40rem) {
    .h-col {
      inline-size: 78vw;
    }

    .h-cols {
      gap: 1.25rem;
    }
  }
</style>
