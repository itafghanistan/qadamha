---
import Base from '../../layouts/Base.astro';
import { LOCALES, useTranslations, type Locale } from '../../i18n';
import { GITHUB_NEW_ISSUE } from '../../config';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);

const planned = Array.from({ length: 6 }, (_, i) => i + 1).map((n) => {
  const title = t(`roadmap.planned.${n}.title`);
  const body = t(`roadmap.planned.${n}.body`);
  const issueUrl =
    `${GITHUB_NEW_ISSUE}?labels=idea&title=` +
    encodeURIComponent(`[Idea] ${title}`) +
    '&body=' +
    encodeURIComponent(`${body}\n\n`);
  return { title, body, issueUrl };
});

const shipped = Array.from({ length: 12 }, (_, i) => i + 1).map((n) => ({
  title: t(`roadmap.shipped.${n}.title`),
  body: t(`roadmap.shipped.${n}.body`),
}));
---

<Base
  locale={locale}
  title={`${t('roadmap.title')} — ${t('site.name')}`}
  description={t('roadmap.intro')}
  path="/roadmap/"
>
  <section class="section">
    <div class="container roadmap">
      <h1>{t('roadmap.title')}</h1>
      <p class="lead">{t('roadmap.intro')}</p>

      <h2>{t('roadmap.planned.title')}</h2>
      <ul class="planned-list">
        {
          planned.map((item) => (
            <li class="planned-item">
              <div class="planned-head">
                <span class="chip chip-muted">{t('roadmap.planned.badge')}</span>
                <h3>{item.title}</h3>
              </div>
              <p>{item.body}</p>
              <a class="btn btn-ghost" href={item.issueUrl} rel="noopener">
                {t('roadmap.planned.requestCta')}
              </a>
            </li>
          ))
        }
      </ul>

      <h2>{t('roadmap.shipped.title')}</h2>
      <ul class="shipped-list">
        {
          shipped.map((item) => (
            <li class="shipped-item">
              <span class="check" aria-hidden="true">
                ✓
              </span>
              <span class="sr-only">{t('roadmap.shipped.badge')}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Base>

<style>
  .roadmap {
    max-width: 56rem;
  }

  .lead {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 44rem;
  }

  .roadmap > h2 {
    margin-block-start: 2.25rem;
    color: var(--accent-strong);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Planned */
  .planned-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .planned-item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
  }

  .planned-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .planned-item h3 {
    font-size: 1rem;
    margin: 0;
  }

  .planned-item p {
    margin: 0;
    color: var(--text-muted);
  }

  .planned-item .btn {
    align-self: start;
    padding: 0.4rem 1.1rem;
    font-size: 0.9rem;
  }

  /* Shipped — dense grid so every feature is visible at a glance */
  .shipped-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.6rem;
  }

  .shipped-item {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.6rem 0.75rem;
  }

  .shipped-item .check {
    flex: none;
    color: var(--accent-strong);
    font-weight: 800;
    line-height: 1.5;
  }

  .shipped-item h3 {
    font-size: 0.9rem;
    margin: 0 0 0.15rem;
  }

  .shipped-item p {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--text-muted);
  }
</style>
