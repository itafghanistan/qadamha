---
import Base from '../../layouts/Base.astro';
import { LOCALES, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);

const shipped = Array.from({ length: 12 }, (_, i) => i + 1).map((n) => ({
  title: t(`roadmap.shipped.${n}.title`),
  body: t(`roadmap.shipped.${n}.body`),
}));

const planned = Array.from({ length: 3 }, (_, i) => i + 1).map((n) => ({
  title: t(`roadmap.planned.${n}.title`),
  body: t(`roadmap.planned.${n}.body`),
}));
---

<Base
  locale={locale}
  title={`${t('roadmap.title')} — ${t('site.name')}`}
  description={t('roadmap.intro')}
  path="/roadmap/"
>
  <section class="section">
    <div class="container roadmap">
      <h1>{t('roadmap.title')}</h1>
      <p class="lead">{t('roadmap.intro')}</p>

      <h2>{t('roadmap.shipped.title')}</h2>
      <ul class="roadmap-list">
        {
          shipped.map((item) => (
            <li class="roadmap-item">
              <span class="chip">{t('roadmap.shipped.badge')}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <h2>{t('roadmap.planned.title')}</h2>
      <ul class="roadmap-list">
        {
          planned.map((item) => (
            <li class="roadmap-item">
              <span class="chip chip-muted">{t('roadmap.planned.badge')}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Base>

<style>
  .roadmap {
    max-width: 46rem;
  }

  .lead {
    font-size: 1.15rem;
    color: var(--text-muted);
  }

  .roadmap > h2 {
    margin-block-start: 2.25rem;
    color: var(--accent-strong);
  }

  .roadmap-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .roadmap-item {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
  }

  .roadmap-item .chip {
    flex: none;
  }

  .roadmap-item h3 {
    font-size: 1rem;
    margin: 0 0 0.25rem;
  }

  .roadmap-item p {
    margin: 0;
    color: var(--text-muted);
  }

  @media (max-width: 30rem) {
    .roadmap-item {
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>
