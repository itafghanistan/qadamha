---
import Base from '../../layouts/Base.astro';
import IdeaCard from '../../components/IdeaCard.astro';
import PostCard from '../../components/PostCard.astro';
import InviteWidget from '../../components/InviteWidget.astro';
import { LOCALES, formatNumber, localizePath, useTranslations, type Locale } from '../../i18n';
import { getIdeas } from '../../lib/ideas';
import { getPosts } from '../../lib/posts';
import { parseContentId } from '../../lib/content-utils';
import { SITE_URL, GITHUB_REPO } from '../../config';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const ideas = await getIdeas(locale);
const featured = ideas.filter((s) => s.data.featured).slice(0, 3);
const fallback = featured.length > 0 ? featured : ideas.slice(0, 3);
const latestPosts = (await getPosts(locale)).slice(0, 3);
const ideaNames = new Map(ideas.map((i) => [parseContentId(i.id).slug, i.data.name]));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Qadamha',
  alternateName: 'قدم‌ها',
  url: SITE_URL,
  sameAs: [GITHUB_REPO],
  description: t('site.description'),
};
---

<Base
  locale={locale}
  title={`${t('site.name')} — ${t('site.tagline')}`}
  description={t('site.description')}
  path="/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="hero">
    <div class="container">
      <p class="kicker">{t('home.hero.kicker')}</p>
      <h1>{t('home.hero.title')}</h1>
      <p class="hero-subtitle">{t('home.hero.subtitle')}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={localizePath(locale, '/ideas/')}>{t('home.hero.cta')}</a>
        <a class="btn btn-ghost" href={localizePath(locale, '/submit/')}
          >{t('home.contribute.cta')}</a
        >
      </div>
      <p class="step-count">
        {t('home.count', { count: formatNumber(locale, ideas.length) })}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('home.featured')}</h2>
      <div class="card-grid">
        {fallback.map((idea) => <IdeaCard idea={idea} locale={locale} />)}
      </div>
      <p class="browse-all">
        <a href={localizePath(locale, '/ideas/')}>{t('home.browseAll')}</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container invite-section">
      <h2>{t('invite.title')}</h2>
      <p>{t('invite.body')}</p>
      <InviteWidget locale={locale} />
    </div>
  </section>

  <section class="section letter">
    <div class="container letter-inner">
      <h2>{t('home.message.title')}</h2>
      <p>{t('home.message.p1')}</p>
      <p>{t('home.message.p2')}</p>
    </div>
  </section>

  {
    latestPosts.length > 0 && (
      <section class="section">
        <div class="container">
          <h2>{t('posts.latest')}</h2>
          <div class="card-grid">
            {latestPosts.map((post) => (
              <PostCard
                post={post}
                locale={locale}
                ideaName={post.data.idea ? ideaNames.get(post.data.idea) : undefined}
              />
            ))}
          </div>
          <p class="browse-all">
            <a href={localizePath(locale, '/posts/')}>{t('posts.all')}</a>
          </p>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container contribute-band">
      <h2>{t('home.contribute.title')}</h2>
      <p>{t('home.contribute.body')}</p>
      <a class="btn btn-primary" href={localizePath(locale, '/submit/')}
        >{t('home.contribute.cta')}</a
      >
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: 5rem 3.5rem;
    background:
      radial-gradient(60rem 30rem at 80% -10%, rgba(232, 163, 61, 0.09), transparent),
      radial-gradient(40rem 20rem at 10% 110%, rgba(232, 163, 61, 0.05), transparent);
    text-align: center;
  }

  .kicker {
    color: var(--accent-strong);
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-block-end: 0.75rem;
  }

  .hero-subtitle {
    max-width: 42rem;
    margin-inline: auto;
    color: var(--text-muted);
    font-size: 1.15rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-block: 1.75rem 2.25rem;
  }

  .step-count {
    color: var(--accent-strong);
    font-weight: 600;
    font-size: 1rem;
  }

  .browse-all {
    margin-block-start: 1.5rem;
    text-align: end;
  }

  .invite-section {
    max-width: 40rem;
    margin-inline: auto;
    text-align: center;
  }

  .invite-section p {
    color: var(--text-muted);
    margin-block-end: 1.75rem;
  }

  .letter {
    background: var(--bg-raised);
    border-block: 1px solid var(--border);
  }

  .letter-inner {
    max-width: 44rem;
    font-size: 1.1rem;
  }

  .letter h2 {
    color: var(--accent-strong);
  }

  .contribute-band {
    text-align: center;
    max-width: 40rem;
  }
</style>
