---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import StepsIllustration from '../../components/StepsIllustration.astro';
import { LOCALES, localizePath, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const submitPath = localizePath(locale, '/submit/');
const ideasPath = localizePath(locale, '/ideas/');

const steps = [
  { icon: 'edit', title: t('invite.page.steps.1.title'), body: t('invite.page.steps.1.body') },
  { icon: 'users', title: t('invite.page.steps.2.title'), body: t('invite.page.steps.2.body') },
  { icon: 'check', title: t('invite.page.steps.3.title'), body: t('invite.page.steps.3.body') },
] as const;
---

<Base
  locale={locale}
  title={`${t('invite.page.cta')} — ${t('site.name')}`}
  description={t('invite.page.body1')}
  path="/invite/"
>
  <section class="section invite-hero">
    <div class="container invite-page">
      <StepsIllustration size={180} />

      <p class="kicker">
        <Icon name="steps" size={14} />
        {t('invite.page.kicker')}
      </p>
      <h1 id="invite-heading" data-title-named={t('invite.page.titleNamed')}>
        {t('invite.page.title')}
      </h1>

      <div id="invite-namecard" class="invite-namecard" hidden>
        <Icon name="steps" size={20} />
        <span id="invite-quote"></span>
      </div>

      <p class="lead">{t('invite.page.body1')}</p>
      <p class="lead">{t('invite.page.body2')}</p>

      <div class="invite-cta-row">
        <a id="invite-cta" class="btn btn-primary" href={submitPath}>
          <Icon name="edit" size={15} />
          {t('invite.page.cta')}
        </a>
        <a class="browse-link" href={ideasPath}>
          {t('invite.page.browse')}
          <Icon name="arrowRight" size={14} />
        </a>
      </div>
    </div>
  </section>

  <section class="section steps-section">
    <div class="container">
      <p class="steps-kicker">{t('invite.page.steps.kicker')}</p>
      <div class="steps-grid">
        {
          steps.map((step, i) => (
            <div class="step-card">
              <span class="step-number">{i + 1}</span>
              <Icon name={step.icon} size={20} />
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<script>
  import { buildInviteSearch } from '../../lib/invite';

  const params = new URLSearchParams(location.search);
  const idea = params.get('idea')?.trim() ?? '';
  const name = params.get('name')?.trim() ?? '';

  const heading = document.getElementById('invite-heading')!;
  const namecard = document.getElementById('invite-namecard')!;
  const quote = document.getElementById('invite-quote')!;
  const cta = document.getElementById('invite-cta') as HTMLAnchorElement;

  if (name) {
    const template = heading.dataset.titleNamed ?? '';
    heading.textContent = template.replace('{name}', name);
  }

  if (idea) {
    quote.textContent = idea;
    namecard.hidden = false;
  }

  const search = buildInviteSearch(idea, name);
  if (search) {
    cta.href = `${cta.getAttribute('href')}${search}`;
  }
</script>

<style>
  .invite-page {
    max-width: 38rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-strong);
    font-weight: 600;
    letter-spacing: 0.03em;
    margin-block-end: 0.75rem;
  }

  .kicker :global(svg) {
    color: var(--accent);
  }

  .lead {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-block: 0 1rem;
    max-width: 34rem;
  }

  .invite-namecard {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-block: 1.5rem;
    padding: 0.85rem 1.4rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 1.2rem;
    font-weight: 700;
    max-width: 100%;
    overflow-wrap: break-word;
  }

  .invite-namecard :global(svg) {
    color: var(--accent);
    flex-shrink: 0;
  }

  .invite-cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    margin-block-start: 1.5rem;
  }

  .invite-cta-row .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .browse-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .browse-link:hover,
  .browse-link:focus-visible {
    color: var(--accent-strong);
    text-decoration: none;
  }

  .steps-section {
    padding-block-start: 0;
  }

  .steps-kicker {
    text-align: center;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-block-end: 1.5rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.25rem;
    max-width: 54rem;
    margin-inline: auto;
  }

  .step-card {
    position: relative;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
  }

  .step-number {
    position: absolute;
    inset-block-start: 1.1rem;
    inset-inline-end: 1.2rem;
    color: var(--border);
    font-weight: 800;
    font-size: 1.4rem;
  }

  .step-card :global(svg) {
    color: var(--accent);
    margin-block-end: 0.75rem;
  }

  .step-card h3 {
    margin-block-end: 0.4rem;
    font-size: 1.05rem;
  }

  .step-card p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0;
  }
</style>
