---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import IdeaCard from '../../../components/IdeaCard.astro';
import PostCard from '../../../components/PostCard.astro';
import PersonLink from '../../../components/PersonLink.astro';
import SideLabel from '../../../components/SideLabel.astro';
import {
  LOCALE_META,
  formatYear,
  localizePath,
  useTranslations,
  type Locale,
} from '../../../i18n';
import { getIdeas, getIdeaTranslations, type Idea } from '../../../lib/ideas';
import { getPostsForIdea } from '../../../lib/posts';
import { getPerson } from '../../../lib/people';
import { getRelated, hueFromSlug, parseContentId } from '../../../lib/content-utils';
import { GITHUB_IDEA_PATH, SITE_URL } from '../../../config';

export async function getStaticPaths() {
  const entries = await getCollection('ideas', (entry) => !entry.data.draft);
  return entries.map((entry) => {
    const { locale, slug } = parseContentId(entry.id);
    return { params: { lang: locale, slug }, props: { entry } };
  });
}

const { entry } = Astro.props as { entry: Idea };
const locale = Astro.params.lang as Locale;
const t = useTranslations(locale);
const { slug } = parseContentId(entry.id);
const { Content } = await render(entry);

const data = entry.data;
const availableLocales = await getIdeaTranslations(slug);
const otherLocales = availableLocales.filter((l) => l !== locale);
const missingLocales = (['en', 'fa', 'ps'] as Locale[]).filter(
  (l) => !availableLocales.includes(l),
);
const related = getRelated(entry, await getIdeas(locale));
const relatedPosts = await getPostsForIdea(locale, slug);
const founders = await Promise.all(
  data.founders.map(async (c) => ({ ...c, profile: await getPerson(c.person) })),
);
const team = await Promise.all(
  (data.team ?? []).map(async (c) => ({ ...c, profile: await getPerson(c.person) })),
);

const years =
  formatYear(locale, data.yearsActive.start) +
  '–' +
  (data.yearsActive.end ? formatYear(locale, data.yearsActive.end) : t('idea.present'));

const hue = hueFromSlug(slug);

/** The original site's domain, extracted from a Wayback-style URL when possible. */
function archivedDomain(archiveUrl: string): string {
  const innerStart = archiveUrl.indexOf('http', 10);
  const candidate = innerStart > 0 ? archiveUrl.slice(innerStart) : archiveUrl;
  try {
    return new URL(candidate).hostname.replace(/^www\./, '');
  } catch {
    return new URL(archiveUrl).hostname.replace(/^www\./, '');
  }
}

const path = `/ideas/${slug}/`;
const pageUrl = new URL(localizePath(locale, path), SITE_URL).href;
const shareText = `${data.name} — ${data.tagline}`;
const shareLinks = [
  { label: 'X', url: `https://x.com/intent/post?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}` },
  { label: 'Facebook', url: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}` },
  { label: 'LinkedIn', url: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}` },
  { label: 'Telegram', url: `https://t.me/share/url?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(shareText)}` },
  { label: 'WhatsApp', url: `https://wa.me/?text=${encodeURIComponent(`${shareText} ${pageUrl}`)}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.name,
  description: data.tagline,
  inLanguage: LOCALE_META[locale].htmlLang,
  url: pageUrl,
  author: data.founders.map((f) => ({ '@type': 'Person', name: f.name })),
  publisher: { '@type': 'Organization', name: 'Qadamha', url: SITE_URL },
};
---

<Base
  locale={locale}
  title={`${data.name} — ${t('site.name')}`}
  description={data.tagline}
  path={path}
  availableLocales={availableLocales}
  ogImage={`/og/ideas/${locale}/${slug}.png`}
  ogType="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="section">
    <div class="container idea-layout">
      <div class="idea-main">
        <header class="idea-header">
          <h1>{data.name}</h1>
          <p class="idea-tagline">{data.tagline}</p>
          {
            otherLocales.length > 0 && (
              <p class="translations">
                {t('idea.alsoAvailable')}
                {otherLocales.map((l) => (
                  <a href={localizePath(l, path)} lang={LOCALE_META[l].htmlLang} class="chip">
                    {LOCALE_META[l].nativeName}
                  </a>
                ))}
              </p>
            )
          }
        </header>

        <div class="prose">
          <Content />
        </div>

        {
          missingLocales.length > 0 && (
            <aside class="translate-invite">
              {missingLocales.map((l) => (
                <p>
                  <a href={localizePath(locale, '/contribute/')}>
                    {t('idea.helpTranslate', { language: LOCALE_META[l].nativeName })}
                  </a>
                </p>
              ))}
            </aside>
          )
        }

        <div class="share-row">
          <span class="share-label">{t('idea.share')}</span>
          {
            shareLinks.map((link) => (
              <a class="chip chip-muted" href={link.url} rel="noopener" target="_blank">
                {link.label}
              </a>
            ))
          }
          <button class="chip chip-muted copy-btn" data-url={pageUrl} data-copied={t('idea.copied')}>
            {t('idea.copyLink')}
          </button>
        </div>

        <p class="edit-link">
          <a href={`${GITHUB_IDEA_PATH}/${locale}/${slug}.md`} rel="noopener">
            {t('idea.editOnGitHub')}
          </a>
        </p>
      </div>

      <aside class="idea-side">
        <div class="side-card">
          <div class="side-brand">
            {
              data.logo ? (
                <img class="idea-logo" src={data.logo} alt="" width="96" height="96" />
              ) : (
                <span
                  class="idea-logo idea-monogram"
                  style={`--logo-hue: ${hue}`}
                  aria-hidden="true"
                >
                  {data.name.trim().charAt(0).toUpperCase()}
                </span>
              )
            }
          </div>

          {
            data.archive && (
              <a class="archive-card" href={data.archive} rel="noopener" target="_blank">
                <span class="archive-chrome" aria-hidden="true">
                  <span class="archive-dot"></span>
                  <span class="archive-dot"></span>
                  <span class="archive-dot"></span>
                  <span class="archive-url" dir="ltr">{archivedDomain(data.archive)}</span>
                </span>
                {
                  data.archiveImage ? (
                    <span class="archive-screen has-image" aria-hidden="true">
                      <img src={data.archiveImage} alt="" loading="lazy" />
                    </span>
                  ) : (
                    <span class="archive-screen" aria-hidden="true" style={`--logo-hue: ${hue}`}>
                      <span class="skeleton-hero">
                        {data.logo ? (
                          <img src={data.logo} alt="" width="26" height="26" />
                        ) : (
                          <span class="skeleton-logo">{data.name.trim().charAt(0).toUpperCase()}</span>
                        )}
                        <span class="skeleton-bar w-40"></span>
                      </span>
                      <span class="skeleton-bar w-90"></span>
                      <span class="skeleton-bar w-75"></span>
                      <span class="skeleton-bar w-55 accent"></span>
                    </span>
                  )
                }
                <span class="archive-cta">{t('idea.archive')} ↗</span>
              </a>
            )
          }

          <dl>
            <SideLabel icon="status" label={t('idea.status')} />
            <dd><span class="chip">{t(`status.${data.status}`)}</span></dd>

            <SideLabel icon="reasons" label={t('idea.reasons')} />
            <dd class="chips">
              {data.reasons.map((r) => <span class="chip chip-muted">{t(`reason.${r}`)}</span>)}
            </dd>

            <SideLabel icon="years" label={t('idea.years')} />
            <dd>{years}</dd>

            <SideLabel icon="city" label={t('idea.city')} />
            <dd>{data.city}</dd>

            <SideLabel icon="sector" label={t('idea.sector')} />
            <dd class="chips">
              {
                data.sectors.map((s) => (
                  <a class="chip chip-muted" href={localizePath(locale, `/categories/${s}/`)}>
                    {t(`sector.${s}`)}
                  </a>
                ))
              }
            </dd>

            <SideLabel icon="founders" label={t('idea.founders')} />
            <dd>
              <ul class="people-list">
                {
                  founders.map((f) => (
                    <li>
                      <PersonLink
                        locale={locale}
                        person={f.profile}
                        name={f.name}
                        link={f.link}
                        role={f.role}
                      />
                    </li>
                  ))
                }
              </ul>
            </dd>

            {
              team.length > 0 && (
                <>
                  <SideLabel icon="team" label={t('idea.team')} />
                  <dd>
                    <ul class="people-list">
                      {team.map((m) => (
                        <li>
                          <PersonLink
                            locale={locale}
                            person={m.profile}
                            name={m.name}
                            role={m.role}
                          />
                        </li>
                      ))}
                    </ul>
                  </dd>
                </>
              )
            }

            {
              data.links && data.links.length > 0 && (
                <>
                  <SideLabel icon="links" label={t('idea.links')} />
                  <dd>
                    <ul>
                      {data.links.map((l) => (
                        <li>
                          <a href={l.url} rel="noopener">
                            {l.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </dd>
                </>
              )
            }

            {
              data.sources && data.sources.length > 0 && (
                <>
                  <SideLabel icon="sources" label={t('idea.sources')} />
                  <dd>
                    <ul>
                      {data.sources.map((s) => (
                        <li>
                          <a href={s.url} rel="noopener">
                            {s.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </dd>
                </>
              )
            }
          </dl>
        </div>
      </aside>
    </div>

    {
      relatedPosts.length > 0 && (
        <div class="container related">
          <h2>{t('idea.relatedPosts')}</h2>
          <div class="card-grid">
            {relatedPosts.map((post) => (
              <PostCard post={post} locale={locale} />
            ))}
          </div>
        </div>
      )
    }

    {
      related.length > 0 && (
        <div class="container related">
          <h2>{t('idea.related')}</h2>
          <div class="card-grid">
            {related.map((idea) => (
              <IdeaCard idea={idea} locale={locale} />
            ))}
          </div>
        </div>
      )
    }
  </article>
</Base>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy-btn');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(btn.dataset.url ?? location.href);
    const original = btn.textContent;
    btn.textContent = btn.dataset.copied ?? original;
    setTimeout(() => (btn.textContent = original), 1600);
  });
</script>

<style>
  /* Sidebar sits in the first column: left in LTR, right (start side) in RTL. */
  .idea-layout {
    display: grid;
    grid-template-columns: 20rem minmax(0, 1fr);
    gap: 3rem;
  }

  .idea-side {
    grid-column: 1;
    grid-row: 1;
  }

  .idea-main {
    grid-column: 2;
    grid-row: 1;
  }

  .idea-header {
    margin-block-end: 1.5rem;
  }

  .idea-tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .translations {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .side-card {
    position: sticky;
    inset-block-start: 4.5rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
    font-size: 0.92rem;
  }

  .side-brand {
    display: flex;
    justify-content: center;
    margin-block-end: 1.2rem;
  }

  .idea-logo {
    inline-size: 96px;
    block-size: 96px;
    border-radius: 22px;
    object-fit: cover;
    background: var(--bg-soft);
  }

  .idea-monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: hsl(var(--logo-hue) 42% 26%);
    color: hsl(var(--logo-hue) 75% 78%);
    font-size: 2.8rem;
    font-weight: 800;
  }

  /* Archive preview — a tiny browser window that begs to be opened. */
  .archive-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-block-end: 1.3rem;
    background: var(--bg);
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .archive-card:hover,
  .archive-card:focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -14px rgba(232, 163, 61, 0.5);
    text-decoration: none;
  }

  .archive-chrome {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.6rem;
    background: var(--bg-soft);
    border-block-end: 1px solid var(--border);
  }

  .archive-dot {
    inline-size: 0.5rem;
    block-size: 0.5rem;
    border-radius: 50%;
    background: var(--border);
  }

  .archive-url {
    flex: 1;
    margin-inline-start: 0.4rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
  }

  .archive-screen {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.9rem;
    background:
      radial-gradient(14rem 8rem at 80% -20%, hsl(var(--logo-hue, 40) 45% 30% / 0.35), transparent),
      var(--bg-raised);
    min-block-size: 6.5rem;
  }

  .archive-screen.has-image {
    padding: 0;
    min-block-size: 0;
  }

  .archive-screen.has-image img {
    display: block;
    inline-size: 100%;
    max-block-size: 10rem;
    object-fit: cover;
    object-position: top;
  }

  .skeleton-hero {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-block-end: 0.2rem;
  }

  .skeleton-hero img {
    border-radius: 6px;
  }

  .skeleton-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 26px;
    block-size: 26px;
    border-radius: 6px;
    background: hsl(var(--logo-hue) 42% 30%);
    color: hsl(var(--logo-hue) 75% 80%);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .skeleton-bar {
    display: block;
    block-size: 0.5rem;
    border-radius: 999px;
    background: var(--bg-soft);
  }

  .skeleton-bar.accent {
    background: var(--accent-soft);
  }

  .skeleton-bar.w-40 {
    inline-size: 40%;
  }

  .skeleton-bar.w-55 {
    inline-size: 55%;
  }

  .skeleton-bar.w-75 {
    inline-size: 75%;
  }

  .skeleton-bar.w-90 {
    inline-size: 90%;
  }

  .archive-cta {
    display: block;
    padding: 0.55rem 0.75rem;
    text-align: center;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent-strong);
    background: var(--accent-soft);
  }

  .idea-side dl {
    margin: 0;
  }

  .idea-side dd {
    margin: 0.35rem 0 0;
  }

  .idea-side ul {
    margin: 0;
    padding-inline-start: 1.1rem;
  }

  .idea-side .people-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .translate-invite {
    background: var(--accent-soft);
    border-radius: var(--radius);
    padding: 0.9rem 1.2rem;
    margin-block: 1.5rem;
    font-size: 0.95rem;
  }

  .translate-invite p {
    margin: 0;
  }

  .share-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-block: 2rem 0.75rem;
  }

  .share-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-inline-end: 0.35rem;
  }

  .copy-btn {
    cursor: pointer;
    font-family: inherit;
  }

  .edit-link {
    font-size: 0.88rem;
  }

  .related {
    margin-block-start: 3.5rem;
  }

  @media (max-width: 56rem) {
    .idea-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .idea-side,
    .idea-main {
      grid-column: auto;
      grid-row: auto;
    }

    .side-card {
      position: static;
    }
  }
</style>
