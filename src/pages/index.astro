---
import '@fontsource-variable/vazirmatn';
import '../styles/global.css';
import { LOCALES, LOCALE_META, localizePath, useTranslations } from '../i18n';
import { SITE_URL, withBase } from '../config';

const tEn = useTranslations('en');

// Locale → site-relative URL (includes the deploy base path).
const targets = Object.fromEntries(LOCALES.map((l) => [l, localizePath(l)]));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <title>Qadamha (قدم‌ها) — Every attempt was a step</title>
    <meta name="description" content={tEn('site.description')} />
    <link rel="canonical" href={new URL(withBase('/'), SITE_URL).href} />
    {
      LOCALES.map((l) => (
        <link
          rel="alternate"
          hreflang={LOCALE_META[l].htmlLang}
          href={new URL(localizePath(l), SITE_URL).href}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath('en'), SITE_URL).href} />

    <script is:inline define:vars={{ targets }}>
      // Pick the visitor's language and redirect immediately.
      // Priority: their saved choice → fa/ps browser language →
      // Afghanistan/Iran timezone (≈ location) → English.
      (function () {
        function go(locale) {
          location.replace(targets[locale]);
        }
        try {
          var saved = localStorage.getItem('qadamha-lang');
          if (saved && targets[saved]) return go(saved);
        } catch (e) {
          /* storage unavailable (private mode) */
        }
        var langs = navigator.languages || [navigator.language || ''];
        for (var i = 0; i < langs.length; i++) {
          var l = String(langs[i]).toLowerCase();
          if (l.indexOf('fa') === 0 || l.indexOf('prs') === 0) return go('fa');
          if (l.indexOf('ps') === 0) return go('ps');
        }
        try {
          var tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
          if (tz === 'Asia/Kabul' || tz === 'Asia/Tehran') return go('fa');
        } catch (e) {
          /* older browsers */
        }
        go('en');
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${targets.en}`} />
    </noscript>
  </head>
  <body>
    <!-- Visible only for the instant before the redirect, or if it fails. -->
    <main class="redirecting">
      <p class="mark" aria-hidden="true">قدم‌ها</p>
      <nav aria-label="Choose your language">
        {
          LOCALES.map((l) => (
            <a href={targets[l]} lang={LOCALE_META[l].htmlLang} dir={LOCALE_META[l].dir}>
              {LOCALE_META[l].nativeName}
            </a>
          ))
        }
      </nav>
    </main>
  </body>
</html>

<style>
  .redirecting {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .mark {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent);
    margin: 0;
  }

  .redirecting nav {
    display: flex;
    gap: 1.5rem;
    font-size: 1.15rem;
    font-weight: 600;
  }
</style>
