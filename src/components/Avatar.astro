---
import { hueFromSlug } from '../lib/content-utils';
import { withBase } from '../config';

interface Props {
  /** Path to the avatar image (e.g. person.data.avatar). */
  src?: string | undefined;
  /** Display name — used for alt text and the initials fallback. */
  name: string;
  /** Key for the deterministic fallback color (person id, or the name). */
  hueKey?: string;
  size?: number;
}

const { src, name, hueKey = name, size = 24 } = Astro.props;
const hue = hueFromSlug(hueKey);
const initial = name.trim().charAt(0).toUpperCase();
---

{
  src ? (
    <img
      class="avatar"
      src={withBase(src)}
      alt=""
      width={size}
      height={size}
      style={`--avatar-size: ${size}px`}
      loading="lazy"
    />
  ) : (
    <span
      class="avatar avatar-fallback"
      style={`--avatar-size: ${size}px; --avatar-hue: ${hue}`}
      aria-hidden="true"
    >
      {initial}
    </span>
  )
}

<style>
  .avatar {
    inline-size: var(--avatar-size, 24px);
    block-size: var(--avatar-size, 24px);
    border-radius: 50%;
    flex-shrink: 0;
    vertical-align: middle;
    object-fit: cover;
  }

  .avatar-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: hsl(var(--avatar-hue) 45% 32%);
    color: hsl(var(--avatar-hue) 70% 82%);
    font-size: calc(var(--avatar-size, 24px) * 0.5);
    font-weight: 700;
    line-height: 1;
  }
</style>
