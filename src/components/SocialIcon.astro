function detect(url: string): keyof typeof ICONS {
  let host = '';
  try {
    host = new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return 'globe';
  }
  if (host === 'github.com') return 'github';
  if (host === 'linkedin.com' || host.endsWith('.linkedin.com')) return 'linkedin';
  if (host === 'x.com' || host === 'twitter.com') return 'x';
  if (host === 'facebook.com' || host === 'fb.com') return 'facebook';
  if (host === 'instagram.com') return 'instagram';
  if (host === 'youtube.com' || host === 'youtu.be') return 'youtube';
  if (host === 't.me' || host === 'telegram.me') return 'telegram';
  return 'globe';
}

const icon = ICONS[detect(url)]!;
const title = label || icon.title;
---

<a class="social-icon" href={url} rel="noopener" target="_blank" title={title} aria-label={title}>
  <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
    <path d={icon.path}></path>
  </svg>
</a>

<style>
  .social-icon {
    display: inline-grid;
    place-items: center;
    inline-size: 2.1rem;
    block-size: 2.1rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .social-icon:hover,
  .social-icon:focus-visible {
    color: var(--accent-strong);
    border-color: var(--accent);
  }
</style>
