---
import type { Locale } from '../i18n';
import { localizePath } from '../i18n';
import type { Person } from '../lib/people';
import { personName } from '../lib/people';
import Avatar from './Avatar.astro';

interface Props {
  locale: Locale;
  /** Profile entry, when the person has one. */
  person?: Person | undefined;
  /** Display name fallback when there is no profile. */
  name?: string | undefined;
  /** External link fallback (e.g. a founder's website) when there is no profile. */
  link?: string | undefined;
  /** Their role, shown on a second line aligned with the name. */
  role?: string | undefined;
  size?: number;
}

const { locale, person, name, link, role, size } = Astro.props;
const displayName = person ? personName(person, locale) : (name ?? '');
const href = person ? localizePath(locale, `/${person.id}/`) : link;
const avatarSize = size ?? (role ? 30 : 22);
---

{
  href ? (
    <a class="person" href={href} rel={person ? undefined : 'noopener'}>
      <Avatar
        src={person?.data.avatar}
        name={person?.data.name ?? displayName}
        hueKey={person?.id ?? displayName}
        size={avatarSize}
      />
      <span class="person-text">
        <span class="person-name">{displayName}</span>
        {role && <span class="person-role">{role}</span>}
      </span>
    </a>
  ) : (
    <span class="person">
      <Avatar src={undefined} name={displayName} size={avatarSize} />
      <span class="person-text">
        <span class="person-name">{displayName}</span>
        {role && <span class="person-role">{role}</span>}
      </span>
    </span>
  )
}

<style>
  .person {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: inherit;
  }

  .person-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
    min-inline-size: 0;
  }

  .person-name {
    font-weight: 600;
  }

  .person-role {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  a.person:hover .person-name,
  a.person:focus-visible .person-name {
    color: var(--accent-strong);
  }

  a.person:hover,
  a.person:focus-visible {
    text-decoration: none;
  }
</style>
