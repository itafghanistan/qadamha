---
import type { Locale } from '../i18n';
import { localizePath, useTranslations } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  path: string;
  availableLocales?: Locale[];
}

const { locale, path, availableLocales } = Astro.props;
const t = useTranslations(locale);

const links = [
  { href: localizePath(locale, '/ideas/'), label: t('nav.ideas') },
  { href: localizePath(locale, '/posts/'), label: t('nav.posts') },
  { href: localizePath(locale, '/timeline/'), label: t('nav.timeline') },
  { href: localizePath(locale, '/about/'), label: t('nav.about') },
  { href: localizePath(locale, '/contribute/'), label: t('nav.contribute') },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={localizePath(locale)}>
      <span class="brand-mark">قدم‌ها</span>
      <span class="brand-name">Qadamha</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <form class="header-search" action={localizePath(locale, '/ideas/')} method="get" role="search">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.8-3.8"></path>
      </svg>
      <input type="search" name="q" placeholder={t('search.placeholder')} aria-label={t('search.label')} />
    </form>
    <LanguageSwitcher locale={locale} path={path} availableLocales={availableLocales} />
  </div>
</header>

<style>
  .site-header {
    border-block-end: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    position: sticky;
    inset-block-start: 0;
    z-index: 10;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-block: 0.7rem;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--text);
  }

  .brand:hover,
  .brand:focus-visible {
    text-decoration: none;
  }

  .brand-mark {
    font-size: 1.45rem;
    font-weight: 800;
    color: var(--accent);
  }

  .brand-name {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .site-nav {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-inline-start: auto;
  }

  .site-nav a {
    color: var(--text);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.95rem;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: var(--accent-soft);
    color: var(--accent-strong);
    text-decoration: none;
  }

  .header-search {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.8rem;
    color: var(--text-muted);
    transition: border-color 0.15s ease;
  }

  .header-search:focus-within {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .header-search input {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: inherit;
    font-size: 0.9rem;
    inline-size: 9.5rem;
  }

  .header-search input::placeholder {
    color: var(--text-muted);
  }

  @media (max-width: 40rem) {
    .brand-name {
      display: none;
    }

    .site-nav {
      order: 3;
      inline-size: 100%;
      margin-inline-start: 0;
    }

    .header-search {
      order: 4;
      inline-size: 100%;
    }

    .header-search input {
      inline-size: auto;
      flex: 1;
    }
  }
</style>
