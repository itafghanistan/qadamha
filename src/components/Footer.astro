---
import type { Locale } from '../i18n';
import { localizePath, useTranslations } from '../i18n';
import { GITHUB_NEW_ISSUE, GITHUB_REPO, SITE_URL } from '../config';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
  /** Path of the current page WITHOUT the locale prefix — prefills the report. */
  path?: string;
}

const { locale, path = '/' } = Astro.props;
const t = useTranslations(locale);

const reportUrl =
  `${GITHUB_NEW_ISSUE}?labels=report&title=` +
  encodeURIComponent(`[Report] ${localizePath(locale, path)}`) +
  '&body=' +
  encodeURIComponent(`Page: ${new URL(localizePath(locale, path), SITE_URL).href}\n\n`);
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-tagline">
      <span class="footer-mark" aria-hidden="true">قدم‌ها</span>
      {t('footer.tagline')}
    </p>
    <p class="footer-meta">
      <a class="footer-link" href={GITHUB_REPO} rel="noopener">
        <Icon name="github" size={14} />
        {t('footer.openSource')}
      </a>
      <span aria-hidden="true"> · </span>
      <a class="footer-link" href={localizePath(locale, '/roadmap/')}>
        <Icon name="steps" size={14} />
        {t('footer.roadmap')}
      </a>
      <span aria-hidden="true"> · </span>
      <a class="footer-link" href={reportUrl} rel="noopener">
        <Icon name="flag" size={14} />
        {t('footer.reportIssue')}
      </a>
      <span aria-hidden="true"> · </span>
      <span>{t('footer.license')}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--border);
    margin-block-start: 4rem;
    padding-block: 2rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-mark {
    color: var(--accent);
    font-weight: 800;
    margin-inline-end: 0.5rem;
  }

  .footer-tagline,
  .footer-meta {
    margin: 0;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .footer-link :global(svg) {
    color: var(--accent);
  }
</style>
