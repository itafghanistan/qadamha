---
import type { Locale } from '../i18n';
import { formatYear, localizePath, useTranslations } from '../i18n';
import type { Story } from '../lib/stories';
import { parseStoryId } from '../lib/story-utils';

interface Props {
  story: Story;
  locale: Locale;
}

const { story, locale } = Astro.props;
const t = useTranslations(locale);
const { slug } = parseStoryId(story.id);
const { name, tagline, sector, city, yearsActive, status } = story.data;
const years =
  formatYear(locale, yearsActive.start) +
  '–' +
  (yearsActive.end ? formatYear(locale, yearsActive.end) : t('story.present'));
---

<a
  class="card"
  href={localizePath(locale, `/stories/${slug}/`)}
  data-slug={slug}
  data-sector={sector}
  data-city={city}
  data-year-start={yearsActive.start}
  data-year-end={yearsActive.end}
  data-status={status}
  data-reasons={story.data.reasons.join(' ')}
>
  <h3>{name}</h3>
  <p class="tagline">{tagline}</p>
  <div class="card-meta">
    <span class="chip">{t(`status.${status}`)}</span>
    <span class="chip chip-muted">{t(`sector.${sector}`)}</span>
    <span class="chip chip-muted">{city}</span>
    <span class="chip chip-muted">{years}</span>
  </div>
</a>
