---
import type { Locale } from '../i18n';
import { LOCALE_META, localizePath } from '../i18n';
import { SITE_URL } from '../config';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Path of the current page WITHOUT locale prefix, e.g. "/ideas/aseel-express/". */
  path: string;
  /**
   * Locales in which this page exists (for hreflang + language switcher).
   * Defaults to all locales, assuming the same path exists everywhere.
   */
  availableLocales?: Locale[];
  /** Absolute or site-relative URL of the social share image. */
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  locale,
  title,
  description,
  path,
  availableLocales = ['en', 'fa', 'ps'],
  ogImage = '/og/site-' + locale + '.png',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(localizePath(locale, path), SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{
  availableLocales.map((l) => (
    <link
      rel="alternate"
      hreflang={LOCALE_META[l].htmlLang}
      href={new URL(localizePath(l, path), SITE_URL).href}
    />
  ))
}
{
  availableLocales.includes('en') && (
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath('en', path), SITE_URL).href} />
  )
}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content={LOCALE_META[locale].htmlLang} />
<meta property="og:site_name" content="Qadamha" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
